assert-command-fails %{ '<a-z>i' }
do-operation-and-check b "'foo' 'abc'"
do-operation-and-check s "'foo' 'bar' 'abc' 'def'"

set-buffer '{(foo) (bar)
(abc) (def)}'
do-operation-and-check u "'foo bar
abc def'"
do-operation-and-check i "'foo' 'bar' 'abc' 'def'"
assert-command-fails %{ '<a-z>b' }
