do-operation-and-check i "'ba'"
do-operation-and-check b "'r ' 'def'"
do-operation-and-check s "'oo ' 'r ' 'ab' 'def'"

set-buffer '{f(oo)( b)a}(r {b)(a}z) {abc} (de{f) g}hi'
